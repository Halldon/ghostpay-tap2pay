# Backend runtime
PORT=4123
GHOSTPAY_REQUEST_DB=./backend/requests-store.json
GHOSTPAY_CLAIM_LOCK_MS=60000
# Optional. Keeps a claim lock from becoming stale even if a tab/connection stalls.
GHOSTPAY_CLAIM_LOCK_TTL_MS=600000
# Optional. Maximum request TTL allowed by the API validation.
GHOSTPAY_REQUEST_TTL_MS=86400000
# Optional. Store cleanup cadence and retention policy.
GHOSTPAY_CLEANUP_INTERVAL_MS=60000
GHOSTPAY_REQUEST_STORE_RETENTION_DAYS=7
GHOSTPAY_REQUIRE_REQUEST_SIGNATURE=false
GHOSTPAY_ADMIN_TOKEN=
GHOSTPAY_MAX_REQUESTS_PER_MERCHANT=500
GHOSTPAY_MAX_BODY_BYTES=65536
GHOSTPAY_POST_RATE_LIMIT_WINDOW_MS=60000
GHOSTPAY_POST_RATE_LIMIT_MAX=120
GHOSTPAY_GET_RATE_LIMIT_WINDOW_MS=60000
GHOSTPAY_GET_RATE_LIMIT_MAX=900
